{
  "manifest_version": 3,
  "name": "Cloudwise Portal",
  "version": "2.0",
  "description": "Cloudwise Portal",
  "permissions": [
    "activeTab",
    "storage",
    "scripting"
  ],
  "host_permissions": [
    "<all_urls>",
    "https://www.google.com/*"
  ],
  "action": {
    "default_icon": {
      "16": "icon.png",
      "48": "icon.png",
      "128": "icon.png"
    },
    "default_title": "Cloudwise"
  },
  "background": {
    "service_worker": "background.js"
  }
}